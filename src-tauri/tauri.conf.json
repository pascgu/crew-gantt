{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrewGantt",
  "version": "../package.json",
  "identifier": "com.pascgu.crewgantt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrewGantt",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "fileAssociations": [
      {
        "ext": ["cgan"],
        "name": "Fichier CrewGantt",
        "description": "Fichier CrewGantt",
        "role": "Editor"
      }
    ]
  }
}
